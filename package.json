{
  "name": "telaude",
  "version": "dev-1.0.3.0-002",
  "description": "Telegram Claude Code Bridge",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "bun scripts/patch-blessed.js",
    "build": "tsc",
    "build:exe": "bun build --compile src/index.ts --outfile telaude.exe --external mock-aws-s3 --external aws-sdk --external nock --external @napi-rs/keyring --external term.js --external pty.js",
    "start": "bun src/index.ts",
    "dev": "bun scripts/dev-loop.mjs",
    "dev:watch": "cross-env NODE_ENV=development bun --watch src/index.ts"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@napi-rs/image": "^1.12.0",
    "@napi-rs/keyring": "^1.2.0",
    "@primno/dpapi": "^2.0.1",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "blessed": "^0.1.81",
    "croner": "^10.0.1",
    "dotenv": "^16.4.7",
    "grammy": "^1.30.0",
    "ignore": "^7.0.5",
    "pino": "^9.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/blessed": "^0.1.27",
    "@types/bun": "^1.2.0",
    "@types/node": "^22.10.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
